{
  "name": "camlio-template",
  "private": true,
  "workspaces": ["frontend", "studio"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=studio\" \"npm run dev --workspace=frontend\"",
    "predev": "npm run sanity:typegen --workspace=frontend",
    "type-check": "npm run type-check --workspace=frontend && npm run type-check --workspace=studio",
    "lint": "npm run lint --workspace=frontend",
    "create-block": "node create-block.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
